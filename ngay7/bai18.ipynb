   "cell_type": "code",
   "source": [
    "import pandas as pd\n",
    "\n",
    "df = pd.DataFrame({\n",
    "    \"A\": [10, -5, 3],\n",
    "    \"B\": [-2, 7, -1]\n",
    "})\n",
    "\n",
    "def color_value(val):\n",
    "    if val > 0:\n",
    "        return \"color: green\"\n",
    "    elif val < 0:\n",
    "        return \"color: red\"\n",
    "    else:\n",
    "        return \"color: black\"\n",
    "\n",
    "df.style.map(color_value)"
   ],
